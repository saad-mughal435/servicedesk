# Local development: copy to `.env` and adjust. Never commit `.env`.

SECRET_KEY=change-me-to-a-long-random-string
DEBUG=true
DEMO_MODE=false

# Only needed when DEBUG=false (production):
# ALLOWED_HOSTS=servicedesk.onrender.com
# CSRF_TRUSTED_ORIGINS=https://servicedesk.onrender.com

# Production database (Neon Postgres). When unset, local dev falls back to SQLite.
# Use the pooled connection string and keep sslmode=require.
# DATABASE_URL=postgres://user:password@ep-xxx-pooler.region.aws.neon.tech/servicedesk?sslmode=require

# Optional: create Saad's superuser non-interactively in the build step.
# DJANGO_SUPERUSER_USERNAME=saad
# DJANGO_SUPERUSER_EMAIL=saad@saadm.dev
# DJANGO_SUPERUSER_PASSWORD=
